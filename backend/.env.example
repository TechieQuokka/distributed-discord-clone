# 복사해서 `.env`로 사용 (D20: 실제 .env는 커밋 금지 — .gitignore 포함).
# 로컬 Postgres가 유닉스 소켓 /var/run/postgresql 포트 48853에서 동작 중.
DATABASE_URL=postgres://david:2147483647@%2Fvar%2Frun%2Fpostgresql:48853/discord_v1
RUST_LOG=info
# REST API 바인드 주소 (기본 127.0.0.1:8080)
REST_ADDR=127.0.0.1:8080
# Snowflake worker id (단일노드 기본 1; 멀티노드는 클러스터 config가 부여, D29)
NODE_WORKER_ID=1
# 노드 id (consistent hashing 링 멤버, 단일노드 기본 1)
NODE_ID=1

# --- 멀티노드(Phase 2, 선택) ---
# 클러스터 설정 TOML 경로 지정 시 멀티노드 모드(raw-TCP+mTLS). 없으면 단일노드.
#CLUSTER_CONFIG=/path/to/node.toml
# mTLS 인증서(공유 CA + 노드 cert/key PEM). `server gen-certs <dir> <id...>`로 생성.
#TLS_CA=/path/to/ca.pem
#TLS_CERT=/path/to/n1.cert.pem
#TLS_KEY=/path/to/n1.key.pem
# 공유 PASETO 키(모든 노드 동일해야 토큰 상호 검증). `server gen-keys`로 생성.
#PASETO_SECRET=<hex>
#PASETO_PUBLIC=<hex>
